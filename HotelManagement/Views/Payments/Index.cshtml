@using HotelManagement.Helper
@{
    ViewData["Title"] = "Payments";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/payments-index.css?v=@Configuration["Assets:Version"]" />

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary mb-0">💲Payments</h2>
    </div>

    <!-- Filters -->
    <div class="card mb-3">
        <div class="card-body p-3">
            <form id="paymentFilterForm" class="row g-3 align-items-end">
                <div class="col-md-3 col-sm-6">
                    <label class="form-label fw-bold">From Date</label>
                    <input type="date" name="fromDate" id="paymentFromDate" class="form-control form-control-sm" />
                </div>
                <div class="col-md-3 col-sm-6">
                    <label class="form-label fw-bold">To Date</label>
                    <input type="date" name="toDate" id="paymentToDate" class="form-control form-control-sm" />
                </div>
                <div class="col-md-3 col-sm-6">
                    <label class="form-label fw-bold">Type</label>
                    <select name="type" id="paymentType" class="form-select form-select-sm" asp-items="ViewBag.PaymentTypes">
                        <option value="">-- All --</option>
                    </select>
                </div>
                <div class="col-md-3 col-12">
                    <div class="d-flex gap-1 flex-wrap flex-md-nowrap justify-content-md-end">
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-range="today">Today</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-range="yesterday">Yesterday</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-range="month">Month</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-range="year">Year</button>
                        <button type="button" class="btn btn-outline-dark btn-sm" id="btnPaymentClear">Clear</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Loading Indicator -->
    <div id="paymentLoadingIndicator" class="text-center py-5" style="display: none;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3">Loading payments...</p>
    </div>

    <!-- Desktop Table -->
    <div class="payments-table-desktop" id="paymentTableDesktop">
        <div class="table-responsive shadow-sm">
            <table class="table table-striped table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>Payment ID</th>
                        <th>Date</th>
                        <th>Invoice No</th>
                        <th>Type</th>
                        <th>Reference</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody id="paymentTableBody">
                    <!-- Content loaded via AJAX -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- Mobile Card Layout -->
    <div class="payments-table-mobile" id="paymentTableMobile">
        <!-- Content loaded via AJAX -->
    </div>

    <!-- Pagination Container -->
    <div id="paymentPaginationContainer"></div>
</div>

<script src="~/js/payments-index.js" asp-append-version="true"></script>