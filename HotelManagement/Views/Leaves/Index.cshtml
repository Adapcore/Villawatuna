@using X.PagedList.Mvc.Core
@using X.PagedList
@using HotelManagement.Enums
@model HotelManagement.Models.ViewModels.LeaveIndexViewModel

@{
    ViewData["Title"] = "Leaves";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var today = DateTime.UtcNow.Date;
    bool isAdmin = ViewBag.IsAdmin != null && (bool)ViewBag.IsAdmin;

    string FormatDays(decimal days) => days == decimal.Truncate(days)
        ? decimal.Truncate(days).ToString("0")
        : days.ToString("0.#");

    var activeRange = (Context?.Request?.Query["range"].ToString() ?? "").Trim().ToLowerInvariant();
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="fw-bold text-primary mb-0 fs-2">🗓️ Employee Leaves</h1>
        <div class="d-flex gap-2">
            <a asp-controller="Leaves" asp-action="Calendar" class="btn btn-outline-primary btn-sm d-flex align-items-center gap-2 px-3 py-2">
                <i class="bi bi-calendar3"></i>
                <span>Calendar</span>
            </a>
            <a asp-controller="Leaves" asp-action="Apply" class="btn btn-success btn-sm d-flex align-items-center gap-2 px-3 py-2">
                <i class="bi bi-plus-circle"></i>
                <span>Add Leave</span>
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="card mb-3">
        <div class="card-body p-3">
            <form method="get" class="row g-3 align-items-end" id="leaveFilterForm">
                <div class="col-md-3 col-sm-6">
                    <label class="form-label fw-bold">Employee</label>
                    <select name="employeeId" id="employeeId" class="form-select form-select-sm" asp-items="Model.Employees">
                        <option value="">-- All --</option>
                    </select>
                </div>
                <div class="col-md-2 col-sm-6">
                    <label class="form-label fw-bold">From Date</label>
                    <input type="date" name="fromDate" id="fromDate" class="form-control form-control-sm" value="@(Model.FromDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>
                <div class="col-md-2 col-sm-6">
                    <label class="form-label fw-bold">To Date</label>
                    <input type="date" name="toDate" id="toDate" class="form-control form-control-sm" value="@(Model.ToDate?.ToString("yyyy-MM-dd") ?? "")" />
                </div>
                <div class="col-md-2 col-sm-6">
                    <label class="form-label fw-bold">Status</label>
                    <select name="status" id="status" class="form-select form-select-sm" asp-items="Model.Statuses"></select>
                </div>
                <div class="col-md-3 col-12">
                    <div class="d-flex gap-2 flex-nowrap justify-content-md-end">
                        <a class="btn btn-sm @(activeRange == "today" ? "btn-secondary" : "btn-outline-secondary")" asp-action="Index" asp-route-range="today">Today</a>
                        <a class="btn btn-sm @(activeRange == "month" ? "btn-secondary" : "btn-outline-secondary")" asp-action="Index" asp-route-range="month">Month</a>
                        <a class="btn btn-sm @(activeRange == "year" ? "btn-secondary" : "btn-outline-secondary")" asp-action="Index" asp-route-range="year">Year</a>
                        <button type="submit" class="btn btn-primary btn-sm">Filter</button>
                        <a class="btn btn-outline-dark btn-sm" asp-action="Index">Clear</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Total days -->
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="small text-muted">
            Ordered by <strong>From Date ASC</strong>
        </div>
        <div class="fw-bold">
            Total Days: <span class="text-primary">@Model.TotalDays.ToString("0.0")</span>
            <span class="mx-2 text-muted">|</span>
            Open Days: <span class="text-primary">@Model.OpenDays.ToString("0.0")</span>
            <span class="mx-2 text-muted">|</span>
            Approved Days: <span class="text-primary">@Model.ApprovedDays.ToString("0.0")</span>
            <span class="mx-2 text-muted">|</span>
            Rejected Days: <span class="text-primary">@Model.RejectedDays.ToString("0.0")</span>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive shadow-sm">
                <table class="table table-striped table-hover table-bordered mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th style="min-width: 70px;">ID</th>
                            <th style="min-width: 200px;">Employee</th>
                            <th style="min-width: 130px;">Requested Date</th>
                            <th style="min-width: 110px;">From Date</th>
                            <th style="min-width: 110px;">To Date</th>
                            <th style="min-width: 80px;" class="text-end">Days</th>
                            <th style="min-width: 180px;">Reason</th>
                            <th style="min-width: 110px;">Status</th>
                            <th style="min-width: 220px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Leaves != null && Model.Leaves.Any())
                        {
                            foreach (var l in Model.Leaves)
                            {
                                var rowClass =
                                    // Old: Green, Today: Red, Future: Blue (light colors)
                                    l.ToDate.Date < today ? "table-success" :
                                    (l.FromDate.Date <= today && l.ToDate.Date >= today) ? "table-danger" :
                                    "table-info";

                                var empName = l.Employee != null
                                    ? $"{l.Employee.FirstName} {l.Employee.LastName}".Trim()
                                    : l.EmployeeId.ToString();

                                <tr class="@rowClass">
                                    <td>@l.ID</td>
                                    <td>@empName</td>
                                    <td>@l.RequestDate.ToString("yyyy-MM-dd")</td>
                                    <td>@l.FromDate.ToString("yyyy-MM-dd")</td>
                                    <td>@l.ToDate.ToString("yyyy-MM-dd")</td>
                                    <td class="text-end">@FormatDays(l.NoOfDays)</td>
                                    <td>@l.Reason</td>
                                    <td>
                                        <span class="badge @(l.Status == LeaveStatus.Approved ? "bg-success" : l.Status == LeaveStatus.Rejected ? "bg-danger" : l.Status == LeaveStatus.Cancelled ? "bg-secondary" : "bg-warning text-dark")">
                                            @l.Status
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1 flex-wrap">
                                            <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", "Leaves", new { id = l.ID })">View</a>
                                            @if (l.Status == LeaveStatus.Open)
                                            {
                                                <a class="btn btn-sm btn-warning" href="@Url.Action("Edit", "Leaves", new { id = l.ID })">Edit</a>
                                            }

                                            @if (isAdmin && l.Status == LeaveStatus.Open)
                                            {
                                                <form asp-controller="Leaves" asp-action="Approve" method="post" class="d-inline js-leave-approve-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@l.ID" />
                                                    <button type="submit" class="btn btn-sm btn-success js-leave-approve-btn" data-leave-id="@l.ID">Approve</button>
                                                </form>
                                                <form asp-controller="Leaves" asp-action="Reject" method="post" class="d-inline js-leave-reject-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@l.ID" />
                                                    <button type="submit" class="btn btn-sm btn-danger js-leave-reject-btn" data-leave-id="@l.ID">Reject</button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center py-4 text-muted">No leaves found for selected filters.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination (preserve filters) -->
    @if (Model.Leaves != null && Model.Leaves.PageCount > 1)
    {
        <div class="d-flex justify-content-center mt-4">
            @Html.PagedListPager(Model.Leaves, page => Url.Action("Index", new
            {
                page,
                employeeId = Model.EmployeeId,
                fromDate = Model.FromDate?.ToString("yyyy-MM-dd"),
                toDate = Model.ToDate?.ToString("yyyy-MM-dd"),
                status = Model.Status
            }),
            new PagedListRenderOptions
            {
                DisplayLinkToFirstPage = PagedListDisplayMode.IfNeeded,
                DisplayLinkToLastPage = PagedListDisplayMode.IfNeeded,
                DisplayLinkToPreviousPage = PagedListDisplayMode.IfNeeded,
                DisplayLinkToNextPage = PagedListDisplayMode.IfNeeded,
                DisplayLinkToIndividualPages = true,
                DisplayItemSliceAndTotal = true,
                MaximumPageNumbersToDisplay = 3,
                UlElementClasses = new[] { "pagination" },
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" }
            })
        </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            if (typeof showConfirmDialog !== 'function') return;

            function bindConfirm(buttonSelector, message, optionsBuilder) {
                document.querySelectorAll(buttonSelector).forEach(function (btn) {
                    btn.addEventListener('click', function (e) {
                        e.preventDefault();
                        e.stopPropagation();

                        var form = btn.closest('form');
                        if (!form) return;

                        var leaveId = btn.getAttribute('data-leave-id') || '';
                        showConfirmDialog(
                            message.replace('{id}', leaveId),
                            function (confirmed) {
                                if (confirmed) form.submit();
                            },
                            optionsBuilder(leaveId)
                        );
                        return false;
                    });
                });
            }

            bindConfirm(
                '.js-leave-approve-btn',
                'Do you want to approve Leave #{id}?',
                function (id) {
                    return { type: 'Success', title: 'Approve Leave', yesButtonText: 'Yes, Approve', noButtonText: 'No', dialogId: 'approveLeaveDialog_' + id };
                }
            );

            bindConfirm(
                '.js-leave-reject-btn',
                'Do you want to reject Leave #{id}?',
                function (id) {
                    return { type: 'Danger', title: 'Reject Leave', yesButtonText: 'Yes, Reject', noButtonText: 'No', warningText: 'This action cannot be undone.', dialogId: 'rejectLeaveDialog_' + id };
                }
            );
        })();
    </script>

    <script>
        (function () {
            var form = document.getElementById('leaveFilterForm');
            if (!form) return;

            function submitIfReady() {
                form.submit();
            }

            ['employeeId', 'fromDate', 'toDate', 'status'].forEach(function (id) {
                var el = document.getElementById(id);
                if (!el) return;
                el.addEventListener('change', submitIfReady);
            });
        })();
    </script>
}

