@model HotelManagement.Models.Entities.Employee

@{
    ViewData["Title"] = "Employee Details";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var fullName = string.Join(" ", new[] { Model.FirstName, Model.LastName }
        .Where(s => !string.IsNullOrWhiteSpace(s)));
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-primary mb-0">Employee Details</h2>
        <div class="d-flex gap-2">
            <a class="btn btn-secondary" href="@Url.Action("Index","Employees")">Back</a>
            <a class="btn btn-warning" href="@Url.Action("Edit","Employees", new { id = Model.ID })">Edit</a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">@Model.ID</dd>

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(fullName) ? "-" : fullName)</dd>

                <dt class="col-sm-3">EPF No</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.EPFNo) ? "-" : Model.EPFNo)</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</dd>

                <dt class="col-sm-3">Contact No</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.ContactNo) ? "-" : Model.ContactNo)</dd>

                <dt class="col-sm-3">NIC</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.NIC) ? "-" : Model.NIC)</dd>

                <dt class="col-sm-3">Address</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Address) ? "-" : Model.Address)</dd>

                <dt class="col-sm-3">Date of Birth</dt>
                <dd class="col-sm-9">@Model.DOB.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Joined Date</dt>
                <dd class="col-sm-9">@(Model.JoinedDate.HasValue ? Model.JoinedDate.Value.ToString("yyyy-MM-dd") : "-")</dd>
            </dl>
        </div>
    </div>
</div>
