@model HotelManagement.Models.Entities.Expense

@{
    ViewData["Title"] = "Expense Detail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-primary mb-0">Expense Details</h2>
        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-secondary" href="@Url.Action("Index","Expenses")">Back</a>
            <a class="btn btn-sm btn-warning" href="@Url.Action("Edit","Expenses", new { id = Model.ID })">Edit</a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">@Model.ID</dd>

                <dt class="col-sm-3">Date</dt>
                <dd class="col-sm-9">@Model.Date.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Expense Type</dt>
                <dd class="col-sm-9">@Model.ExpenseType</dd>

                <dt class="col-sm-3">Payee Name</dt>
                <dd class="col-sm-9">@Model.PayeeName</dd>

                <dt class="col-sm-3">Payment Method</dt>
                <dd class="col-sm-9">@Model.PaymentMethod</dd>

                <dt class="col-sm-3">Amount</dt>
                <dd class="col-sm-9">@Model.Amount.ToString("N2")</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Description) ? "-" : Model.Description)</dd>

                <dt class="col-sm-3">Attachment</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.Attachment))
                    {
                        <a href="@Model.Attachment" target="_blank" rel="noopener noreferrer">View attachment</a>
                    }
                    else
                    {
                        <span>-</span>
                    }
                </dd>
            </dl>
        </div>
    </div>
</div>
