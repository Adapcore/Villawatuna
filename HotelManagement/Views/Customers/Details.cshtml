@model HotelManagement.Models.Entities.Customer

@{
    ViewData["Title"] = "Customer Details";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var fullName = string.Join(" ", new[] { Model.FirstName, Model.LastName }
        .Where(s => !string.IsNullOrWhiteSpace(s)));
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-primary mb-0">Customer Details</h2>
        <div class="d-flex gap-2">
            <a class="btn btn-secondary" href="@Url.Action("Index","Customers")">Back</a>
            <a class="btn btn-warning" href="@Url.Action("Edit","Customers", new { id = Model.ID })">Edit</a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">@Model.ID</dd>

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(fullName) ? "-" : fullName)</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</dd>

                <dt class="col-sm-3">Contact No</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.ContactNo) ? "-" : Model.ContactNo)</dd>

                <dt class="col-sm-3">Passport No</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.PassportNo) ? "-" : Model.PassportNo)</dd>

                <dt class="col-sm-3">Room No</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.RoomNo) ? "-" : Model.RoomNo)</dd>

                <dt class="col-sm-3">Country</dt>
                <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Country) ? "-" : Model.Country)</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @if (Model.Active)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </dd>
            </dl>
        </div>
    </div>
</div>

